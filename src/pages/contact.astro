---
import BaseLayout from "../layouts/BaseLayout.astro";
const email = "info.exil@exil-jp.net";
---

<BaseLayout title="お問い合わせ | 合同会社EXIL">
  <section class="container" style="padding:70px 20px;">
    <div class="badge">Contact</div>
    <h1 class="h1">お問い合わせ</h1>
    <p class="p" style="max-width:760px;">
      ご相談内容を確認のうえ、通常1〜2営業日以内にご連絡いたします。<br/>
      お急ぎの場合は <a href={`mailto:${email}`} style="color:var(--text);text-decoration:underline;">{email}</a> へご連絡ください。
    </p>

    <hr class="hr" />

    <div class="card" style="max-width:760px;">
      <h2 class="h2">フォーム</h2>

      <form id="contact-form">

        <div class="grid" style="grid-template-columns:1fr 1fr;">
          <label class="small">
            会社名<br />
            <input name="company" required
              style="width:100%;margin-top:6px;padding:12px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.03);color:var(--text);" />
          </label>

          <label class="small">
            氏名<br />
            <input name="name" required
              style="width:100%;margin-top:6px;padding:12px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.03);color:var(--text);" />
          </label>
        </div>

        <div class="grid" style="grid-template-columns:1fr 1fr;margin-top:12px;">
          <label class="small">
            メールアドレス<br />
            <input type="email" name="email" required
              style="width:100%;margin-top:6px;padding:12px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.03);color:var(--text);" />
          </label>

          <label class="small">
            相談種別<br />
            <select name="category"
              style="width:100%;margin-top:6px;padding:12px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.03);color:var(--text);">
              <option>インフラ受託開発</option>
              <option>インフラ構築・刷新</option>
              <option>インフラSES</option>
              <option>その他</option>
            </select>
          </label>
        </div>

        <label class="small" style="display:block;margin-top:12px;">
          内容<br />
          <textarea name="message" rows="6" required
            style="width:100%;margin-top:6px;padding:12px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.03);color:var(--text);"></textarea>
        </label>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:14px;">
          <button type="submit" class="btn">送信する</button>
          <span id="form-message" class="small"></span>
        </div>

      </form>

      <p class="small" style="margin-top:12px;">
        プライバシーポリシーは 
        <a href="/security" style="color:var(--text);text-decoration:underline;">こちら</a>
      </p>
    </div>
  </section>

  <!-- ここにJS追加（見た目には影響なし） -->
  <script>
    const form = document.getElementById("contact-form");
    const message = document.getElementById("form-message");

    form.addEventListener("submit", async function(e) {
      e.preventDefault();

      const data = new FormData(form);

      <!-- ここだけ変更 -->
      const response = await fetch("https://formspree.io/f/maqdkynl", {
        method: "POST",
        body: data,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        message.textContent = "送信されました。ありがとうございます。";
        message.style.color = "#16a34a";
        form.reset();
      } else {
        message.textContent = "送信に失敗しました。時間をおいて再度お試しください。";
        message.style.color = "#dc2626";
      }
    });
  </script>

</BaseLayout>