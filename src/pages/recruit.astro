---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="採用情報 | 合同会社EXIL">
  <section class="container" style="padding:100px 20px; text-align:center; max-width:800px;">

    <div class="badge">Recruit</div>
    <h1 class="h1">採用情報</h1>

    <p class="p" style="margin-top:20px;">
      現在の募集要項および応募については、以下の外部サイトよりご確認ください。
    </p>

    <div style="margin-top:40px;">
      <a 
        href="https://en-gage.net/exil-jp_saiyo/" 
        target="_blank"
        rel="noopener noreferrer"
        style="
          display:inline-block;
          background:black;
          color:white;
          padding:14px 28px;
          border-radius:999px;
          font-weight:600;
          text-decoration:none;
        "
      >
        採用ページへ移動する
      </a>
    </div>

  </section>
</BaseLayout>
